{
  "manifest_version": 3,
  "name": "Accessabilitizer",
  "version": "1.0",
  "description": "Enable accessibility versions of websites.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>", "http://localhost/*", "http://127.0.0.1/*"],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
  {
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }
]
}